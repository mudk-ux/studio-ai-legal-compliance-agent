# ---------------------------------------------------------------------------
# Studio Compliance — environment configuration
#
# Copy this file to `.env` (or export the variables in your shell) and fill in
# the values for YOUR GCP project. Nothing in this repository is tied to a
# specific project: every deployment target comes from these variables.
# ---------------------------------------------------------------------------

# Required: the GCP project you are deploying to.
STUDIO_PROJECT_ID=your-gcp-project-id

# Region for Vertex AI + Agent Engine. Agent Engine is not available in every
# region; us-central1 is the safest default.
STUDIO_LOCATION=us-central1

# Required for deployment and for evals against a deployed engine:
# a GCS bucket (gs://...) used for Agent Engine staging and asset uploads.
# The Terraform module in ./terraform can create this for you.
STUDIO_STAGING_BUCKET=gs://your-staging-bucket

# Models. These are real, generally-available Gemini model IDs.
STUDIO_COORDINATOR_MODEL=gemini-2.5-flash
STUDIO_SPECIALIST_MODEL=gemini-2.5-pro

# Where Human-in-the-Loop pending-review records are persisted.
# Local directory path, or a gs://bucket/prefix for shared/serverless use.
STUDIO_HITL_STORE=./hitl_store

# Video Intelligence operation timeout in seconds. LOGO_RECOGNITION on a
# 12-minute 1080p file needs well over the old 600s default.
STUDIO_VIDEO_OPERATION_TIMEOUT_S=1800

# Whether the LLM script-analysis pass is required for TEXT_SCREENPLAY assets.
# true  = an LLM failure fails the report (recommended for production).
# false = deterministic-only script reports, clearly marked as scope-limited.
STUDIO_LLM_REQUIRED=true
